<div class="form-container" role="region" aria-label="Sign up">
  <h1>Sign up</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form", role: "form", 'aria-label': 'Sign up form' }) do |f| %>
    <div class="form-field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", 'aria-label': 'Email address' %>
      <% if resource.errors[:email].present? %>
        <p class="field-error"><%= resource.errors[:email].first %></p>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "new-password", class: "form-input", 'aria-label': 'Password' %>
      <% if resource.errors[:password].present? %>
        <p class="field-error"><%= resource.errors[:password].first %></p>
      <% end %>
    </div>

    <div class="form-field">
      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input", 'aria-label': 'Password confirmation' %>
    </div>

    <div class="form-actions">
      <%= f.submit "Sign up", class: "form-submit-btn" %>
    </div>
  <% end %>

 <div style="text-align:center; margin-top: 0.75rem;">
    <%- if devise_mapping.registerable? %>
      <p><%= link_to "Sign up", new_registration_path(resource_name) %></p>
    <% end %>
  </div>
</div>
