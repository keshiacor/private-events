<h1>Hi <%= current_user.email %> 👋🏽, here are your events</h1>

<h2>My Upcoming Events</h2>
<section class="events-grid" aria-label="Your upcoming events">
  <% @accessible_events.where("event_date >= ?", Date.today).each do |event| %>
    <article class="event-card" aria-labelledby="user-event-<%= event.id %>-title">
      <div class="event-date-badge" aria-hidden="true"><span class="badge-month"><%= event.event_date.strftime("%b") %></span><span class="badge-day"><%= event.event_date.strftime("%d") %></span></div>
      <div class="event-card-body">
        <h3 id="user-event-<%= event.id %>-title" class="event-title"><%= link_to event.name, event_path(event) %></h3>
        <p class="event-meta"><%= event.location %> • <%= event.event_date.strftime("%B %d, %Y %H:%M") %></p>
      </div>
    </article>
  <% end %>
</section>


<h2>My Past Events</h2>
<section class="events-grid" aria-label="Your past events">
  <% @accessible_events.where("event_date < ?", Date.today).each do |event| %>
    <article class="event-card" aria-labelledby="user-event-<%= event.id %>-title">
      <div class="event-date-badge" aria-hidden="true"><span class="badge-month"><%= event.event_date.strftime("%b") %></span><span class="badge-day"><%= event.event_date.strftime("%d") %></span></div>
      <div class="event-card-body">
        <h3 id="user-event-<%= event.id %>-title" class="event-title"><%= link_to event.name, event_path(event) %></h3>
        <p class="event-meta"><%= event.location %> • <%= event.event_date.strftime("%B %d, %Y %H:%M") %></p>
      </div>
    </article>
  <% end %>
</section>

<div class="form-actions" style="justify-content:flex-start; margin-top:1rem;">
  <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn" %>
</div>