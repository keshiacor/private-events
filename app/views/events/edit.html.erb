<div class="form-container" role="region" aria-label="Edit event">
  <h1>Edit Event</h1>
  <%= form_with model: @event, class: "event-form", html: { role: "form", 'aria-label': 'Edit event form' } do |form| %>
    <div class="form-field">
      <%= form.label :name, "Event Name:" %>
      <%= form.text_field :name, class: "form-input", 'aria-label': 'Event name' %>
      <% name_error = @event.errors[:name].first %>
      <% if name_error.present? %>
        <p class="field-error"><%= name_error %></p>
      <% end %>
    </div>
    <div class="form-field">
      <%= form.label :location, "Location:" %>
      <%= form.text_field :location, class: "form-input", 'aria-label': 'Location' %>
      <% location_error = @event.errors[:location].first %>
      <% if location_error.present? %>
        <p class="field-error"><%= location_error %></p>
      <% end %>
    </div>
    <div class="form-field">
      <%= form.label :event_date, "Date of the event:" %>
      <%= form.date_select :event_date %>
      <% date_error = @event.errors[:event_date].first %>
      <% if date_error.present? %>
        <p class="field-error"><%= date_error %></p>
      <% end %>
    </div>
    <div class="form-actions">
      <%= form.submit "Update Event", class: "form-submit-btn" %>
      <%= link_to "Cancel", event_path(@event), class: "btn-secondary" %>
    </div>
  <% end %>
</div>
